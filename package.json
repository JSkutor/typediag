{
  "name": "typediag",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "run-p typecheck lint format:check",
    "validate": "run-p typecheck lint test",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:up": "docker compose up -d",
    "db:studio": "drizzle-kit studio",
    "db:seed": "npx tsx src/db/seed.ts",
    "db:test:setup": "npx tsx scripts/ensureTestDatabase.ts && DATABASE_URL=postgresql://typediag:typediag@localhost:5432/typediag_test npx drizzle-kit push --force",
    "db:cleanup-test-users": "npx tsx --env-file=.env.local scripts/cleanupTestUsers.ts",
    "db:embed": "npx tsx --env-file=.env.local scripts/embedBatch.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.7",
    "d3-delaunay": "^6.0.4",
    "drizzle-orm": "^0.45.2",
    "es-hangul": "^2.3.8",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "next": "16.2.7",
    "postgres": "^3.4.9",
    "posthog-js": "^1.395.0",
    "posthog-node": "^5.38.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.184.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3-delaunay": "^6.0.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "better-sqlite3": "^12.11.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.10.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.4",
    "typescript": "^5",
    "vitest": "^3.2.6",
    "zod": "^4.4.3"
  }
}
