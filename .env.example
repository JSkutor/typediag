# PostgreSQL (TimescaleDB via docker compose)
DATABASE_URL=postgresql://typediag:typediag@localhost:5432/typediag

# Vitest only — npm run test uses this DB instead of DATABASE_URL above
TEST_DATABASE_URL=postgresql://typediag:typediag@localhost:5432/typediag_test

# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Auth routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/ko
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/ko
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/ko

# Guest session HMAC (required in production; min 16 chars)
GUEST_TOKEN_SECRET=change-me-to-a-long-random-secret

# Topic Mode — vector search (https://console.upstage.ai)
UPSTAGE_API_KEY=...

# Topic Mode — LLM generation (https://platform.openai.com/api-keys)
OPENAI_API_KEY=...
